# ==============================================
# Zelo BJJ - Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env.local e preencha:
# cp .env.example .env.local
# ==============================================

# --- Supabase ---
# Dashboard: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# --- Stripe ---
# Dashboard: https://dashboard.stripe.com → Developers → API keys
# IMPORTANTE: Use chaves de TESTE (pk_test_ / sk_test_) até validar tudo
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Stripe Product/Price IDs ---
# Criar em: https://dashboard.stripe.com → Products
# Cada plano precisa de um produto com recorrência mensal
STRIPE_PRICE_INICIANTE=price_...
STRIPE_PRICE_COMPLETO=price_...
STRIPE_PRICE_PRESENCIAL=price_...

# --- Bunny Stream ---
# Dashboard: https://dash.bunny.net → Stream → Video Library
BUNNY_STREAM_API_KEY=sua-api-key
BUNNY_STREAM_LIBRARY_ID=seu-library-id
BUNNY_STREAM_CDN_HOSTNAME=seu-hostname.b-cdn.net

# --- Resend ---
# Dashboard: https://resend.com → API Keys
# Domínio zelobjj.com.br precisa ser verificado no Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=contato@zelobjj.com.br

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
