# ==============================================
# Zelo BJJ - Variaveis de Ambiente
# ==============================================
# Copie este arquivo para .env.local e preencha:
# cp .env.example .env.local
# ==============================================

# --- Supabase ---
# Dashboard: https://supabase.com/dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# --- PagBank ---
# 1) Crie 3 produtos/links de assinatura no painel PagBank (Iniciante R$97, Completo R$197, Presencial R$297).
#    Cada link fica algo como: https://pag.ae/xxxxxxxx ou https://assinaturas.pagseguro.uol.com.br/...
#    Os links sao lidos da tabela `plans.payment_link` no Supabase (rode UPDATE).
#
# 2) Cadastre o webhook na conta PagBank apontando para:
#    https://zelobjj.com.br/api/webhooks/pagbank
#
# 3) Autenticacao do webhook via Basic Auth
#    No painel do PagBank (Notificacoes), cadastre a URL no formato:
#      https://PAGBANK_WEBHOOK_USERNAME:PAGBANK_WEBHOOK_PASSWORD@zelobjj.com.br/api/webhooks/pagbank
#    O PagBank envia Authorization: Basic base64(user:pass) em cada notificacao.
PAGBANK_WEBHOOK_USERNAME=zelobjj_pagbank
PAGBANK_WEBHOOK_PASSWORD=troque-por-uma-senha-forte

# 4) Token da API PagBank (opcional, para uso futuro com API de assinaturas/consulta de transacoes)
PAGBANK_API_TOKEN=

# 5) (opcional) Secret HMAC caso o PagBank passe a enviar assinatura via header
PAGBANK_WEBHOOK_SECRET=

# --- Bunny Stream ---
# Dashboard: https://dash.bunny.net -> Stream -> Video Library
# - Server-only: usadas em routes /api/admin/bunny/* (criar/deletar video, assinar TUS)
BUNNY_STREAM_API_KEY=sua-api-key
BUNNY_STREAM_LIBRARY_ID=seu-library-id
BUNNY_STREAM_CDN_HOSTNAME=seu-hostname.b-cdn.net
# - Public (precisam do prefixo NEXT_PUBLIC_): consumidas pelo VideoPlayer no client
#   Repita o MESMO valor de BUNNY_STREAM_LIBRARY_ID e BUNNY_STREAM_CDN_HOSTNAME aqui
NEXT_PUBLIC_BUNNY_LIBRARY_ID=seu-library-id
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=seu-hostname.b-cdn.net

# --- Resend ---
# Dashboard: https://resend.com -> API Keys
# Dominio zelobjj.com.br precisa ser verificado no Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=contato@zelobjj.com.br

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
